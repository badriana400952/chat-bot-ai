generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("PRISMA_DATABASE_URL")
}

model Message {
  id             Int      @id @default(autoincrement())
  customerNumber String?
  sender         String
  message        String
  createdAt      DateTime @default(now())
}